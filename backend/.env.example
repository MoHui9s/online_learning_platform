# ===== 应用 =====
APP_NAME=EduPlatform
APP_ENV=development
DEBUG=true

# ===== 认证 / JWT =====
# 用 `openssl rand -hex 32` 生成，切勿提交真实值
SECRET_KEY=change-me-to-a-random-32-byte-hex
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=10080

# ===== Cookie / CSRF(关键决策 1:JWT 存 HttpOnly Cookie + CSRF 双提交) =====
# 本地 http 开发时 COOKIE_SECURE=false;生产必须 true
COOKIE_SECURE=false
# 同源部署用 lax;跨站前端用 none(此时 COOKIE_SECURE 必须为 true)
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
# CSRF 双提交:后端下发的可读 cookie 名 + 前端回传的 header 名
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token

# ===== 数据库 MySQL 8.0 =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=edu_platform

# ===== Redis 7.0 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== LLM / Embedding(OpenAI 兼容,可切 Ollama) =====
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your-key
LLM_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-ada-002

# ===== 向量库 / 上传 =====
# ChromaDB 容器内监听 8000, docker-compose 将宿主端口映射为 8001,
# 把宿主 8000 留给后端 uvicorn。因此后端连接 Chroma 用 8001。
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./chroma_data
UPLOAD_DIR=./uploads

# ===== CORS(逗号分隔;cookie 跨站需精确域名,不能用 *) =====
CORS_ORIGINS=http://localhost:5173
